# API and worker
DATABASE_URL=postgresql+psycopg://signal:signal@db:5432/palestine_signals
POSTGRES_HOST_PORT=55432
API_HOST_PORT=18000
API_PUBLIC_URL=http://127.0.0.1:18000/api
FRONTEND_ORIGIN=http://127.0.0.1:5173
SCHEDULE_SECONDS=21600
RETENTION_DAYS=90

# Telegram user-session connector
# Create API credentials in Telegram, fill both values, then run:
# docker compose run --rm api python -m app.telegram_login
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=/app/sessions/telegram.session
TELEGRAM_DISCOVERY_QUERIES=فلسطين,غزة,الضفة,Palestine,Gaza

# Discord bot connector
DISCORD_BOT_TOKEN=

# News candidate discovery feeds. Add comma-separated RSS/Atom feed URLs.
NEWS_DISCOVERY_FEED_URLS=
NEWS_DISCOVERY_KEYWORDS=فلسطين,غزة,الضفة,Palestine,Gaza,West Bank
